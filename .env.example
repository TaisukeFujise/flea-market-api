# .env.example
PORT=8080
ENV=local

GOOGLE_CLOUD_PROJECT=term9-taisuke-fujise

DATABASE_URL=postgres://postgres:flea_local@db:5432/flea?sslmode=disable

# 外部API（Secret Managerから取得。ローカルは直接記載）
GEMINI_API_KEY=
MESHY_API_KEY=
MESHY_WEBHOOK_SECRET=

# Vertex AI
VERTEX_AI_LOCATION=us-central1

# Cloud Storage
GCS_BUCKET_NAME=term9-taisuke-fujise-assets

# CORS
FRONTEND_ORIGIN=http://localhost:3000
